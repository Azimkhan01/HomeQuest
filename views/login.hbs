<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
     {{>commonCss}}
    <link rel="stylesheet" type="text/css" href="/public/CascadingStyle/login.css" />
</head>
<body>
    <div id="container">
        <h1 style="padding-top: 25px;">Log In</h1>
          <form action="/login" method="post">
             <input class="inp" type="text" name="email" placeholder="Email" />
             <input class="inp" type="password" name="password" placeholder="Password" autocomplete="on"/>
             <input class="inp subbtn" type="submit" value="Log In"/>
             <a href="/">Not Registered ? Signup Now</a>
             <p style="text-align: center;color:red">{{error}}</p>
          </form>
    </div>
</body>
</html>